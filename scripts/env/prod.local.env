AWS_REGION=us-east-1
AWS_ACCOUNT_ID=876067771140

# ECR repository name (without the account/region URI)
ECR_REPOSITORY=racestats-backend

# Full App Runner service ARN — found in the App Runner console
APP_RUNNER_SERVICE_ARN=arn:aws:apprunner:us-east-1:876067771140:service/racestats-backend/01ff0d75a7b1406dbd23f65ddc9f45b1

# S3 bucket that holds the built React app
S3_BUCKET_UI=racestats-ui-prod

# S3 bucket for ephemeral session data (24-hr lifecycle rule applied at creation)
S3_BUCKET_SESSIONS=racestats-sessions-prod

# CloudFront distribution ID for the frontend
CLOUDFRONT_DISTRIBUTION_ID=E328PQT8G84Y9

# Public domains
UI_DOMAIN=racestats.robfiero.net
API_DOMAIN=api.racestats.robfiero.net

# Docker image tag to build and deploy
BACKEND_IMAGE_TAG=latest

# Must match App Runner architecture
DOCKER_PLATFORM=linux/amd64
